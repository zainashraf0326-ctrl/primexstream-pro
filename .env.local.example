# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Copy your values from: https://app.supabase.com/project/[YOUR_PROJECT]/settings/api

# Get these from Supabase Dashboard:
# 1. Go to Settings → API
# 2. Copy "Project URL" (this is your SUPABASE_URL)
# 3. Copy "anon public" key (this is your SUPABASE_ANON_KEY)

# Example values (REPLACE WITH YOUR OWN):
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Your actual keys go here:
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ============================================
# FIREBASE CONFIGURATION
# ============================================
# Copy your values from: Firebase Console -> Project settings -> General
# Realtime Database URL comes from: Firebase Console -> Realtime Database

NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id

# ============================================
# APP CONFIGURATION
# ============================================

NEXT_PUBLIC_APP_URL=http://localhost:3000

# For production:
# NEXT_PUBLIC_APP_URL=https://yourdomain.com

# ============================================
# PAYMENT PROVIDERS (Optional)
# ============================================

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Razorpay (for India)
NEXT_PUBLIC_RAZORPAY_KEY_ID=your_key_id
RAZORPAY_SECRET=your_secret

# ============================================
# EMAIL SERVICE (Optional)
# ============================================

# Sendgrid, Mailgun, or other email service
EMAIL_FROM=noreply@primexstream.com
SENDGRID_API_KEY=SG....

# ============================================
# HOW TO SET UP
# ============================================
# 
# 1. Create a Supabase project:
#    - Go to https://supabase.com
#    - Click "New Project"
#    - Fill in project details
#    - Wait for project to initialize
#
# 2. Get your API keys:
#    - Go to Settings → API
#    - Copy Project URL → NEXT_PUBLIC_SUPABASE_URL
#    - Copy anon public → NEXT_PUBLIC_SUPABASE_ANON_KEY
#
# 3. Create the database:
#    - Open SQL Editor
#    - Create new query
#    - Copy ALL code from SUPABASE_SETUP.sql
#    - Paste it in the editor
#    - Click "Run"
#
# 4. Fill in the values below and save as .env.local in your project root
#
# ============================================
