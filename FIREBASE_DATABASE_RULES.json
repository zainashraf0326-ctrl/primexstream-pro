{
  "rules": {
    ".read": false,
    ".write": false,
    "users": {
      ".read": "auth != null && (auth.token.email === 'zainashraf0326@gmail.com' || auth.token.email === 'admin@primexstream.com')",
      "$uid": {
        ".read": "auth != null && ($uid === auth.uid || auth.token.email === 'zainashraf0326@gmail.com' || auth.token.email === 'admin@primexstream.com')",
        ".write": "auth != null && ($uid === auth.uid || auth.token.email === 'zainashraf0326@gmail.com' || auth.token.email === 'admin@primexstream.com')",
        "name": {
          ".validate": "newData.isString()"
        },
        "email": {
          ".validate": "newData.isString()"
        },
        "orders": {
          "$orderId": {
            ".validate": "newData.hasChildren(['createdAt'])"
          }
        },
        "notifications": {
          "$notificationId": {
            ".validate": "newData.hasChildren(['createdAt'])"
          }
        },
        "adminReplies": {
          "$replyId": {
            ".validate": "newData.hasChildren(['createdAt'])"
          }
        }
      }
    },
    "uploads": {
      ".read": "auth != null",
      "$uploadId": {
        ".write": "auth != null && ((!data.exists() && newData.child('userId').val() === auth.uid) || data.child('userId').val() === auth.uid || auth.token.email === 'zainashraf0326@gmail.com' || auth.token.email === 'admin@primexstream.com')",
        ".validate": "newData.hasChildren(['userId', 'fileName', 'imageUrl', 'createdAt'])"
      }
    }
  }
}
